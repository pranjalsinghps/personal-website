---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import { experiences } from "../data/experience";
---

<BaseLayout
  title="Experience"
  description="Professional experience in quality assurance, product operations, and business analysis."
>
  <div class="flex flex-col gap-12">
    <div class="flex flex-col gap-4 pb-8 fade-up">
      <p class="text-xs uppercase tracking-[0.45em] text-[var(--color-subtle)]">
        Work
      </p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight">
        Experience
      </h1>
    </div>

    <div class="flex flex-col gap-6">
      {experiences.map((exp, i) => (
        <div class="fade-up" style={`animation-delay: ${i * 0.1}s;`}>
          <ExperienceCard experience={exp} showBullets={true} />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
