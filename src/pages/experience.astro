---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import TechBadge from "../components/TechBadge.astro";
import { experiences } from "../data/experience";
import { skills } from "../data/skills";
---

<BaseLayout
  title="Experience"
  description="Professional experience in quality assurance, product operations, and business analysis."
>
  <div class="flex flex-col gap-12">
    <div class="flex flex-col gap-4 pb-8 fade-up">
      <p class="text-xs uppercase tracking-[0.45em] text-[var(--color-subtle)]">
        Work
      </p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight">
        Experience
      </h1>
    </div>

    <div class="flex flex-col gap-6">
      {experiences.map((exp, i) => (
        <div class="fade-up" style={`animation-delay: ${i * 0.1}s;`}>
          <ExperienceCard experience={exp} showBullets={true} />
        </div>
      ))}
    </div>

    <!-- Skills -->
    <section id="skills" class="flex flex-col gap-8 fade-up" style="animation-delay: 0.4s;">
      <h2 class="text-xs font-semibold uppercase tracking-[0.35em] text-[var(--color-subtle)] pb-3">
        Skills & Tools
      </h2>
      {skills.map((group) => (
        <div class="flex flex-col gap-4">
          <h3 class="text-sm font-semibold text-[var(--color-muted)]">
            {group.label}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((skill) => (
              <TechBadge name={skill} />
            ))}
          </div>
        </div>
      ))}
    </section>
  </div>
</BaseLayout>
