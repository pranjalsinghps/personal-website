---
import BaseLayout from "../layouts/BaseLayout.astro";
import { education } from "../data/education";
---

<BaseLayout
  title="Education"
  description="Academic background in computer applications with coursework in IT, system analysis, and business operations."
>
  <div class="flex flex-col gap-12">
    <div class="flex flex-col gap-4 pb-8 fade-up">
      <p class="text-xs uppercase tracking-[0.45em] text-[var(--color-subtle)]">
        Academic
      </p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight">
        Education
      </h1>
    </div>

    <div class="flex flex-col gap-6">
      {education.map((edu, i) => (
        <div
          class="flex flex-col gap-4 rounded-2xl bg-white/5 p-6 fade-up"
          style={`animation-delay: ${i * 0.1}s;`}
        >
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex flex-col gap-1">
              <h3 class="text-lg font-semibold text-[var(--color-foreground)]">
                {edu.institution}
              </h3>
              <p class="text-sm text-[var(--color-muted)]">
                {edu.degree}
              </p>
            </div>
            <div class="flex flex-col items-start sm:items-end gap-1">
              <span class="text-xs uppercase tracking-[0.3em] text-[var(--color-subtle)]">
                {edu.period}
              </span>
              <span class="text-xs text-[var(--color-subtle)]">
                {edu.location}
              </span>
            </div>
          </div>
          {edu.description && (
            <p class="text-sm text-[var(--color-muted)]">
              {edu.description}
            </p>
          )}
        </div>
      ))}
    </div>

    <!-- Journey reference -->
    <div class="fade-up" style="animation-delay: 0.2s;">
      <a
        href="/blog/from-sports-dreams-to-tech-career"
        class="group flex items-center gap-3 rounded-2xl bg-white/5 p-6 transition-all duration-300 hover:-translate-y-1 hover:bg-white/10"
      >
        <div class="flex flex-col gap-1">
          <p class="text-sm text-[var(--color-muted)] group-hover:text-[var(--color-foreground)] transition-colors">
            Curious how I ended up in tech? I wrote about the unexpected journey, from sports aspirations to a computer science degree.
          </p>
          <span class="text-xs uppercase tracking-[0.2em] text-[var(--color-subtle)] group-hover:text-[var(--color-foreground)] transition-colors flex items-center gap-1">
            Read the story
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>
