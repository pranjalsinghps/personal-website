---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Projects"
  description="A focused set of projects spanning product design, quality engineering, and system builds."
>
  <div class="flex flex-col gap-12">
    <div class="flex flex-col gap-4 pb-8 fade-up">
      <p class="text-xs uppercase tracking-[0.45em] text-[var(--color-subtle)]">
        Work
      </p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight">
        Selected Projects
      </h1>
      <p class="text-[var(--color-muted)] leading-relaxed max-w-2xl">
        Projects built with a focus on reliability, clarity, and precise execution.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      {projects.map((project, i) => (
        <div class="fade-up" style={`animation-delay: ${i * 0.1}s;`}>
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
