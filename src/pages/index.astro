---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BlogEntry from "../components/BlogEntry.astro";
import { siteConfig } from "../data/site";
import { experiences } from "../data/experience";
import { projects } from "../data/projects";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const featuredExperiences = experiences.slice(0, 2);
const featuredProjects = projects.filter((p) => p.featured).slice(0, 2);

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteConfig.name,
  url: siteConfig.url,
  jobTitle: siteConfig.role,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Bengaluru",
    addressCountry: "IN",
  },
  sameAs: ["https://linkedin.com/in/pranjal-singh"],
};
---

<BaseLayout jsonLd={personJsonLd}>
  <div class="flex flex-col gap-20">
    <!-- Hero -->
    <section class="flex flex-col gap-7 pb-12 fade-up">
      <p class="text-xs uppercase tracking-[0.45em] text-[var(--color-subtle)]">
        {siteConfig.role}
      </p>
      <div class="flex flex-col gap-3">
        <h1 class="text-5xl sm:text-6xl font-semibold leading-tight">
          {siteConfig.name}
        </h1>
        <p class="text-[var(--color-muted)] leading-relaxed max-w-2xl">
          {siteConfig.description}
        </p>
      </div>
      <SocialLinks />
    </section>

    <!-- Selected Experience -->
    <section class="flex flex-col gap-6 fade-up" style="animation-delay: 0.1s;">
      <div class="flex justify-between items-end pb-3">
        <h2 class="text-xs font-semibold uppercase tracking-[0.35em] text-[var(--color-subtle)]">
          Experience
        </h2>
        <a
          class="text-xs text-[var(--color-subtle)] hover:text-[var(--color-foreground)] flex items-center gap-1 transition-colors"
          href="/experience"
        >
          View all
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="flex flex-col gap-5">
        {featuredExperiences.map((exp) => (
          <ExperienceCard experience={exp} />
        ))}
      </div>
    </section>

    <!-- Selected Projects -->
    {featuredProjects.length > 0 && (
      <section class="flex flex-col gap-6 fade-up" style="animation-delay: 0.2s;">
        <div class="flex justify-between items-end pb-3">
          <h2 class="text-xs font-semibold uppercase tracking-[0.35em] text-[var(--color-subtle)]">
            Selected Projects
          </h2>
          <a
            class="text-xs text-[var(--color-subtle)] hover:text-[var(--color-foreground)] flex items-center gap-1 transition-colors"
            href="/projects"
          >
            View all
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          {featuredProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </section>
    )}

    <!-- Writing -->
    {allPosts.length > 0 && (
      <section class="flex flex-col gap-6 fade-up" style="animation-delay: 0.3s;">
        <div class="flex justify-between items-end pb-3">
          <h2 class="text-xs font-semibold uppercase tracking-[0.35em] text-[var(--color-subtle)]">
            Writing
          </h2>
          <a
            class="text-xs text-[var(--color-subtle)] hover:text-[var(--color-foreground)] flex items-center gap-1 transition-colors"
            href="/blog"
          >
            Read all
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="flex flex-col">
          {allPosts.map((post) => (
            <BlogEntry
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
